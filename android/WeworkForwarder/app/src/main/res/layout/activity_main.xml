<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="企微消息采集转发"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- 无障碍服务状态 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tv_accessibility_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="无障碍服务：未开启"
            android:textSize="14sp"
            android:textColor="#F44336" />

        <Button
            android:id="@+id/btn_accessibility"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="去开启"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- 源群名称 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:text="源群名称:"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/et_source_group"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="14sp"
            android:inputType="text"
            android:singleLine="true" />
    </LinearLayout>

    <!-- 目标群 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:text="目标群:"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/et_target_groups"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="14sp"
            android:inputType="text"
            android:hint="多个群用逗号分隔，最多9个"
            android:singleLine="true" />
    </LinearLayout>

    <!-- 回溯分钟 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:text="回溯分钟:"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/et_lookback"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="10"
            android:textSize="14sp"
            android:inputType="number" />
    </LinearLayout>

    <!-- 轮询间隔 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:text="轮询间隔(秒):"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/et_poll_interval"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="30"
            android:textSize="14sp"
            android:inputType="number" />
    </LinearLayout>

    <!-- 按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btn_start"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="启动采集"
            android:backgroundTint="#1E88E5" />

        <Button
            android:id="@+id/btn_stop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="停止"
            android:layout_marginStart="16dp"
            android:backgroundTint="#757575" />

        <Button
            android:id="@+id/btn_dump"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="分析控件"
            android:layout_marginStart="16dp"
            android:backgroundTint="#FF9800" />
    </LinearLayout>

    <!-- 日志区域 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="运行日志:"
        android:textSize="14sp"
        android:layout_marginTop="16dp" />

    <ScrollView
        android:id="@+id/scroll_log"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:padding="8dp"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/tv_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#333333"
            android:fontFamily="monospace" />
    </ScrollView>

</LinearLayout>
